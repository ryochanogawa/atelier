{
  "name": "atelier-cli",
  "version": "0.1.0",
  "description": "AI Agent Orchestration CLI - Subscription-based, DDD Architecture",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "atelier": "./bin/atelier.js"
  },
  "scripts": {
    "copy:builtin": "rm -rf dist/builtin/commissions dist/builtin/palettes dist/builtin/policies dist/builtin/contracts dist/builtin/instructions dist/builtin/knowledge && cp -R src/builtin/commissions dist/builtin/commissions && cp -R src/builtin/palettes dist/builtin/palettes && cp -R src/builtin/policies dist/builtin/policies && cp -R src/builtin/contracts dist/builtin/contracts && cp -R src/builtin/instructions dist/builtin/instructions && cp -R src/builtin/knowledge dist/builtin/knowledge",
    "build": "tsc -p tsconfig.build.json && npm run copy:builtin",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t atelier-cli .",
    "docker:run": "docker run --rm -it atelier-cli"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "execa": "^9.3.0",
    "googleapis": "^171.4.0",
    "handlebars": "^4.7.8",
    "ink": "^5.1.0",
    "nanoid": "^5.0.7",
    "ora": "^8.0.1",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.0",
    "react": "^18.3.0",
    "simple-git": "^3.25.0",
    "ws": "^8.20.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.5.0",
    "prettier": "^3.3.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "ai",
    "agent",
    "orchestration",
    "cli",
    "ddd"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
