{
  "name": "atelier-cli",
  "version": "0.1.0",
  "description": "AI Agent Orchestration CLI - Subscription-based, DDD Architecture",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "atelier": "./bin/atelier.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t atelier-cli .",
    "docker:run": "docker run --rm -it atelier-cli"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "execa": "^9.3.0",
    "simple-git": "^3.25.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.0",
    "handlebars": "^4.7.8",
    "nanoid": "^5.0.7",
    "ora": "^8.0.1",
    "cli-table3": "^0.6.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0",
    "tsx": "^4.15.0",
    "eslint": "^9.5.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "prettier": "^3.3.0"
  },
  "keywords": ["ai", "agent", "orchestration", "cli", "ddd"],
  "license": "MIT"
}
